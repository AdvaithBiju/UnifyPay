{
  "version": 4,
  "min_app_version_code": 15,
  "latest_version_code": 15,
  "update_message": "New version: smarter scam/promo detection using a trust-weighted scoring model instead of keyword blocklists. Update now!",
  "routing_rules": [
    { "sender_contains": ["HDFC"], "parser": "hdfc" },
    { "sender_contains": ["ICICI"], "parser": "icici" },
    { "sender_contains": ["SBI", "SBMSMS"], "parser": "generic" },
    { "sender_contains": ["AXIS"], "parser": "generic" },
    { "sender_contains": ["SIBSMS", "SIB-"], "parser": "southindian" },
    { "sender_contains": ["KOTAKB"], "parser": "generic" },
    { "sender_contains": ["INDBNK"], "parser": "generic" },
    { "sender_contains": ["YESBK"], "parser": "generic" },
    { "sender_contains": ["FEDERAL"], "parser": "generic" },
    { "sender_contains": ["PAYTM"], "parser": "generic" },
    { "sender_contains": ["PHONEPE"], "parser": "generic" },
    { "sender_contains": ["CANARA", "CNRBNK"], "parser": "generic" }
  ],
  "pre_filter": {
    "otp_pattern": "\\bOTP\\b|\\bone.?time\\s*pass",
    "url_pattern": "(?:https?://|www\\.|(?:[a-zA-Z0-9-]+\\.)+[a-z]{2,}/)",
    "shortlink_domains": [
      "cutt.ly", "bit.ly", "tinyurl.com", "is.gd", "rebrand.ly",
      "t.co", "rb.gy", "shorturl.at", "tiny.cc", "lnkd.in"
    ],
    "balance_keywords": ["balance", "bal"],
    "trans_keywords": [
      "debit", "credit", "debited", "credited", "spent", "sent",
      "received", "transaction", "upi debit", "upi credit",
      "withdrawal", "payment successful", "dr."
    ],
    "promo_keywords": [
      "offer", "win", "discount", "free", "loan", "apply now",
      "click", "expires", "off", "gift", "plan", "visit", "enjoy",
      "connection", "postpaid", "prepaid", "recharge offer",
      "upgrade", "activate", "bonus", "reward", "cashback",
      "explore now", "smart mobile hack", "hack:"
    ],
    "non_transaction_keywords": [
      "days position", "fa bal", "click view", "securities name",
      "securities", "nav", "units allotted", "folio"
    ],
    "statement_keywords": ["minimum due", "payment due", "statement", "bill generated"],
    "trans_verbs": [
      "debited", "credited", "spent", "deducted", "received",
      "deposited", "transferred", "recharged", "auto-debit", "emi",
      "withdrawal", "payment successful"
    ],
    "ref_patterns": ["RRN", "Ref No", "UTR", "Txn ID", "UPI Ref", "Transaction ID", "Ref", "Txn"],
    "outcome_reject_patterns": ["declined", "has failed", "was not successful", "reversed", "unsuccessful", "transaction failed"],
    "classification_order": [
      "otp_pattern",
      "non_transaction_keywords",
      "shortlink_no_ref_check",
      "promo_keywords",
      "statement_keywords",
      "trans_keywords"
    ],
    "shortlink_no_ref_rule": "If message matches any shortlink_domains AND contains none of ref_patterns, classify as non-transaction regardless of trans_keywords matches."
  },
  "sender_classification": {
    "enabled": true,
    "enforce_promotional_suffix_reject": false,
    "dlt_suffix_pattern": "-([A-Z])$",
    "promotional_suffixes": ["P"],
    "service_suffixes": ["S", "T"],
    "government_suffixes": ["G"]
  },
  "scoring": {
    "enabled": true,
    "threshold_trusted_sender": 6,
    "threshold_untrusted_sender": 8,
    "min_reference_length": 4,
    "future_tense_patterns": [
      "will\\s+be\\s+(credited|debited)",
      "shall\\s+be\\s+(credited|debited)",
      "to\\s+be\\s+deducted",
      "is\\s+due\\s+on"
    ],
    "amount_negative_context": ["worth", "off", "up to", "upto", "starting at", "@", "plan at", "only rs", "flat"],
    "weights": {
      "known_bank_sender": 3,
      "explicit_debited_credited_verb": 5,
      "valid_reference_number": 4,
      "account_mask_present": 3,
      "amount_present_unnegated": 2,
      "generic_transaction_verb": 2,
      "balance_with_verb": 1,
      "url_present": -3,
      "shortlink_domain": -5,
      "promo_keyword": -3,
      "amount_negative_context_hit": -4,
      "unknown_sender": -2,
      "future_tense_hit": -6
    }
  },
  "transaction_types": {
    "debit_verbs": [
      "debited", "deducted", "spent", "sent",
      "payment successful", "dr."
    ],
    "credit_verbs": ["credited", "received", "deposited", "refund"]
  },
  "reference_patterns": [
    "RRN\\s*:\\s*([a-zA-Z0-9]+)",
    "Ref\\s*No\\s*([a-zA-Z0-9]+)",
    "UTR\\s*:\\s*([a-zA-Z0-9]+)",
    "Txn\\s*ID\\s*:\\s*([a-zA-Z0-9]+)",
    "UPI\\s*Ref\\s*:\\s*([a-zA-Z0-9]+)",
    "Transaction\\s*ID\\s*([a-zA-Z0-9]+)",
    "Ref\\s*([a-zA-Z0-9]{6,})",
    "UPI\\s*:\\s*([0-9]{6,})"
  ],
  "merchant_categories": {
    "Food": ["zomato", "swiggy", "restaurant", "cafe", "food", "pizza", "biryani", "dine"],
    "Travel": ["uber", "ola", "rapido", "metro", "bus", "train", "irctc", "cab", "auto", "petrol", "pump", "fuel", "bp", "shell", "ioc"],
    "Bills": ["electricity", "bescom", "bsnl", "airtel", "jio", "broadband", "recharge"],
    "Shopping": ["amazon", "flipkart", "myntra", "shop", "store", "mart"],
    "Health": ["pharmacy", "hospital", "clinic", "medplus", "apollo"]
  }
}
